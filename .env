# API base URL — empty = uses hardcoded Render fallback in api.js
VITE_API_URL=

# ── EmailJS ────────────────────────────────────────────────────────────────────
# Steps:
#  1. Go to https://www.emailjs.com and sign up (free)
#  2. Add Email Service (e.g. Gmail) → copy the Service ID
#  3. Create Email Template → copy the Template ID
#     Template variables to use: {{from_name}} {{from_phone}} {{from_email}}
#                                {{plot_size}} {{message}} {{source}} {{to_email}}
#  4. Account → API Keys → copy your Public Key
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Admin email that receives enquiry notifications
VITE_ADMIN_EMAIL=info@abivyagroup.com
